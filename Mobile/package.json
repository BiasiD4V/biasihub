{
  "name": "biasihub-mobile",
  "version": "1.0.52",
  "description": "BiasíHub Mobile (Android APK via Capacitor)",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare-www": "node prepare-www.mjs",
    "patch:android": "node patch-android.mjs",
    "sync": "cap sync android",
    "build:android": "npm run prepare-www && npm run sync && cd android && gradlew.bat assembleRelease",
    "build:android:debug": "npm run prepare-www && npm run sync && cd android && gradlew.bat assembleDebug",
    "open:android": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/browser": "^7.0.0",
    "@capacitor/core": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0"
  }
}
